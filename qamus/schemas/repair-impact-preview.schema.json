{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/repair-impact-preview.schema.json",
  "title": "Qamus repair impact preview",
  "type": "object",
  "required": [
    "preview_id",
    "target_address",
    "scope",
    "before",
    "after",
    "changed_fields",
    "affected_token_count",
    "affected_hover_count",
    "affected_parse_key_count",
    "affected_tokens",
    "affected_hover_slots",
    "affected_parse_keys",
    "sample_tokens_are_complete",
    "gate",
    "rollback",
    "live_mutation_allowed",
    "public_boundary"
  ],
  "additionalProperties": false,
  "properties": {
    "preview_id": { "type": "string", "pattern": "^repair-preview:" },
    "target_address": { "type": "string", "pattern": "^qamus:" },
    "scope": { "type": "string", "enum": ["token_only", "parse_family", "entry_sense", "unsafe"] },
    "before": {},
    "after": {},
    "changed_fields": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^qamus:.+#field=" }
    },
    "affected_token_count": { "type": "integer", "minimum": 0 },
    "affected_hover_count": { "type": "integer", "minimum": 0 },
    "affected_parse_key_count": { "type": "integer", "minimum": 0 },
    "affected_tokens": {
      "type": "array",
      "items": { "type": "string", "pattern": "^quran:\\d{1,3}:\\d{1,3}:\\d{1,3}$" }
    },
    "affected_hover_slots": {
      "type": "array",
      "items": { "type": "string", "pattern": "^wbw:\\d{1,3}:\\d{1,3}:\\d{1,3}$" }
    },
    "affected_parse_keys": {
      "type": "array",
      "items": { "type": "string", "pattern": "^parse:[0-9a-f]+$" }
    },
    "sample_tokens_are_complete": { "type": "boolean" },
    "gate": {
      "type": "string",
      "enum": ["token_review", "auto_safe_after_preview", "two_vote_required", "human_review_required", "owner_review_required", "never_auto"]
    },
    "rollback": {
      "type": "object",
      "required": ["strategy", "artifact"],
      "additionalProperties": false,
      "properties": {
        "strategy": { "type": "string", "enum": ["append_only_revert", "restore_backup", "no_apply_preview_only"] },
        "artifact": { "type": "string", "minLength": 1 }
      }
    },
    "live_mutation_allowed": { "const": false },
    "public_boundary": { "$ref": "public-private-boundary.schema.json" }
  }
}
