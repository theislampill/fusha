{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/production-bug-lesson.schema.json",
  "title": "Qamus production bug lesson",
  "type": "object",
  "required": [
    "bug_class",
    "token_addresses",
    "visible_bad_hover",
    "corrected_hover_or_pending_reason",
    "what_failed",
    "sarf_lesson",
    "nahw_lesson",
    "learner_explanation",
    "drill_prompt",
    "level",
    "procedure_links",
    "regression_fixture_link",
    "validator_link",
    "source_addresses"
  ],
  "additionalProperties": false,
  "properties": {
    "bug_class": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "token_addresses": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^quran:\\d{1,3}:\\d{1,3}:\\d{1,3}$" }
    },
    "visible_bad_hover": { "type": "string", "minLength": 1 },
    "corrected_hover_or_pending_reason": { "type": "string", "minLength": 1 },
    "what_failed": { "type": "string", "minLength": 1 },
    "sarf_lesson": { "type": "string", "minLength": 1 },
    "nahw_lesson": { "type": "string", "minLength": 1 },
    "learner_explanation": { "type": "string", "minLength": 1 },
    "drill_prompt": { "type": "string", "minLength": 1 },
    "level": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
    "procedure_links": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "regression_fixture_link": { "type": "string", "minLength": 1 },
    "validator_link": { "type": "string", "minLength": 1 },
    "source_addresses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^(quran|wbw):\\d{1,3}:\\d{1,3}:\\d{1,3}$"
      }
    },
    "edit_intent_id": { "type": ["string", "null"], "pattern": "^edit-intent:" },
    "requested_scope": { "type": ["string", "null"], "enum": ["token_only", "parse_family", "entry_sense", "unsafe", null] },
    "target_address": { "type": ["string", "null"], "minLength": 1 },
    "parse_id": { "type": ["string", "null"], "pattern": "^parse:[0-9a-f]+$" },
    "decision_id": { "type": ["string", "null"], "pattern": "^decision:" },
    "entry_sense": { "type": ["string", "null"], "pattern": "^qamus:.+#sense=\\d+$" },
    "gate": {
      "type": ["string", "null"],
      "enum": ["token_review", "auto_safe_after_preview", "two_vote_required", "human_review_required", "owner_review_required", "never_auto", null]
    },
    "blocker": { "type": ["string", "null"], "pattern": "^blocker:" }
  }
}
