{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/parser-check-ir.schema.json",
  "title": "Fusha Parser/Checker IR — CheckUnit",
  "description": "The FPC-IR container that unifies document>sentence>token>claim>issue>verdict>evidence into one addressable artifact. The Token sub-objects are morphosyntax-token records (qamus/schemas/morphosyntax-token.schema.json), validated separately by tools/validate_morphosyntax_token_metadata.py; the Issue sub-objects are grammar-issue records (qamus/schemas/grammar-issue.schema.json). This schema constrains the CheckUnit's own fields; deep token/issue validation is composed in tools/validate_parser_check.py. See parserplans/001-parser-checker-ir-contract.md.",
  "type": "object",
  "required": ["schema", "source_unit", "segments", "tokens", "claims", "issues", "verdicts", "public_boundary", "summary"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "fusha/parser-check-ir@1" },
    "unit_id": { "type": ["string", "null"] },
    "source_unit": {
      "type": "object",
      "required": ["address", "kind", "scope", "display_surface"],
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string",
          "minLength": 1,
          "description": "quran:S:A | qamus:<id> | qamus:<id>#usage=S:A — must resolve to a source-address graph node, else scope=out_of_scope."
        },
        "kind": { "type": "string", "enum": ["qamus_entry", "qamus_example_card", "quran_ayah"] },
        "scope": { "type": "string", "enum": ["in_scope_source_addressed", "out_of_scope"] },
        "display_surface": { "type": "string", "description": "Verbatim Arabic; never altered." }
      }
    },
    "segments": {
      "type": "array",
      "description": "Sentence/ayah/example-card fragments. tokens are joined by loc.",
      "items": {
        "type": "object",
        "required": ["canonical_loc", "token_locs"],
        "additionalProperties": true,
        "properties": {
          "canonical_loc": { "type": "string", "pattern": "^quran:\\d{1,3}:\\d{1,3}$" },
          "display_surface": { "type": ["string", "null"] },
          "display_local_loc": { "type": ["string", "null"] },
          "display_local_crosswalk": { "type": ["string", "object", "null"] },
          "token_locs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "tokens": {
      "type": "array",
      "description": "morphosyntax-token records (see morphosyntax-token.schema.json). additionalProperties allowed: deep validation is delegated.",
      "items": {
        "type": "object",
        "required": ["loc", "surface", "src", "kind", "lang"],
        "additionalProperties": true,
        "properties": {
          "loc": { "type": "string", "pattern": "^\\d{1,3}:\\d{1,3}:\\d{1,3}$" },
          "surface": { "type": "string", "minLength": 1 },
          "src": { "const": "qamus" },
          "kind": { "const": "authored" },
          "lang": { "const": "en" }
        }
      }
    },
    "claims": {
      "type": "array",
      "description": "Proposed analyses to adjudicate (from an untrusted proposer).",
      "items": {
        "type": "object",
        "required": ["claim_id", "target", "claim_type", "claimed_value", "proposer"],
        "additionalProperties": false,
        "properties": {
          "claim_id": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1, "description": "loc | wbw_loc | loc:G | governor->dependent loc-pair." },
          "claim_type": {
            "type": "string",
            "enum": ["irab_role", "particle_function", "case_mood", "governor", "pp_attachment", "suffix_referent", "parse_key", "hover_gloss", "segmentation"]
          },
          "claimed_value": { "type": "string" },
          "claimed_reasoning": { "type": ["string", "null"] },
          "claimed_gate": { "type": ["string", "null"], "enum": ["auto_safe", "two_vote_required", "human_source_review_required", "never_auto_resolve", null] },
          "grammar_triggers": { "type": "array", "items": { "type": "string" } },
          "token_contribution": { "type": ["string", "null"], "description": "For a phrase-level gloss, the token's own contribution split out (else phrase-as-token is a violation)." },
          "proposer": { "type": "string", "enum": ["model", "tutor", "curriculum", "import"] }
        }
      }
    },
    "issues": {
      "type": "array",
      "description": "grammar-issue records (validated against grammar-issue.schema.json in tools/validate_parser_check.py).",
      "items": { "type": "object", "additionalProperties": true }
    },
    "verdicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "status", "gate", "issue_ids", "route_to", "reasoning_checked"],
        "additionalProperties": false,
        "properties": {
          "claim_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["grounded", "pending", "contradicted", "out_of_scope", "needs_two_vote", "needs_human_review", "unsafe_reasoning"]
          },
          "gate": { "type": "string", "enum": ["auto_safe", "two_vote_required", "human_source_review_required", "never_auto_resolve"] },
          "issue_ids": { "type": "array", "items": { "type": "string" } },
          "route_to": { "type": "array", "items": { "type": "string" } },
          "reasoning_checked": { "type": "boolean" }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "labels": { "type": "array", "items": { "type": "string" }, "description": "Internal-only; never public." },
        "gate": { "type": ["string", "null"] }
      }
    },
    "public_boundary": {
      "type": "object",
      "required": ["public_gloss_src", "public_gloss_kind", "public_gloss_lang", "external_source_names_public"],
      "additionalProperties": false,
      "properties": {
        "public_gloss_src": { "const": "qamus" },
        "public_gloss_kind": { "const": "authored" },
        "public_gloss_lang": { "const": "en" },
        "external_source_names_public": { "const": false }
      }
    },
    "summary": {
      "type": "object",
      "required": ["live_writes", "by_verdict", "by_issue_class"],
      "additionalProperties": false,
      "properties": {
        "live_writes": { "const": 0 },
        "by_verdict": { "type": "object" },
        "by_issue_class": { "type": "object" }
      }
    }
  }
}
