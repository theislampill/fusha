{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/blocker-linkage.schema.json",
  "title": "Qamus blocker linkage",
  "type": "object",
  "required": ["blocker_id", "reason", "blocked_tokens", "status"],
  "additionalProperties": false,
  "properties": {
    "blocker_id": { "type": "string", "pattern": "^blocker:" },
    "reason": { "type": "string" },
    "blocked_tokens": {
      "type": "array",
      "items": { "type": "string", "pattern": "^quran:\\d{1,3}:\\d{1,3}:\\d{1,3}$" }
    },
    "group_by": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["pending", "human_review_required", "source_repair_required", "owner_required"] }
  }
}
