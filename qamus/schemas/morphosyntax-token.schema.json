{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/morphosyntax-token.schema.json",
  "title": "Qamus per-token morphosyntax metadata",
  "description": "Internal, source-addressed grammar metadata for a Quran token. This is separate from the concise public hover gloss. It records POS, morphology, clitics, case/mood/state, agreement, and dependency links so hovers can be checked and future teaching UI can show a breakdown without stuffing source labels or long grammar notes into data-tr.",
  "type": "object",
  "required": ["loc", "wbw_loc", "surface", "key", "gloss", "src", "kind", "lang", "decision_state", "pos", "sarf", "nahw", "parse_key", "display", "learner_explanation", "blocker", "evidence", "public_boundary"],
  "additionalProperties": false,
  "properties": {
    "loc": {
      "type": "string",
      "pattern": "^\\d{1,3}:\\d{1,3}:\\d{1,3}$",
      "description": "Quran token address S:A:W."
    },
    "wbw_loc": {
      "type": "string",
      "pattern": "^wbw:\\d{1,3}:\\d{1,3}:\\d{1,3}$",
      "description": "Exact Qamus word-by-word hover slot address. This is the rendered hover identity, separate from the Quran token identity."
    },
    "surface": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\s]+$",
      "description": "Exact written Quran token surface. Must stay whitespace-free; breakdown belongs in segments, not visible gaps."
    },
    "key": {
      "type": "string",
      "minLength": 1,
      "description": "Lookup/display key for the token. This is not certification; norm-only recall is never enough for rich certification."
    },
    "gloss": {
      "type": "string",
      "minLength": 1,
      "description": "Concise, authored Qamus hover contribution. It must be source-clean and may not copy external wording."
    },
    "src": { "const": "qamus" },
    "kind": { "const": "authored" },
    "lang": { "const": "en" },
    "decision_state": {
      "type": "string",
      "enum": ["rich_candidate", "rich_certified", "pending", "blocked", "token_only_override"],
      "description": "Rich-hover state. Rich certification requires the address, public-boundary, sarf, nahw, learner, source/two-vote, and renderer gates."
    },
    "lemma": { "type": ["string", "null"] },
    "root": { "type": ["string", "null"] },
    "pos": {
      "type": "string",
      "enum": ["noun", "proper_noun", "pronoun", "demonstrative", "adjective", "participle", "masdar", "verb", "particle", "preposition", "conjunction", "subordinating_conjunction", "relative", "time_adverb", "locative_adverb", "interrogative", "interrogative_particle", "equalization_particle", "negative_particle", "accusative_particle", "preventive_particle", "emphatic_particle", "resumption_particle", "result_particle", "supplemental_particle", "cause_particle", "vocative_particle", "prohibitive_particle", "exceptive_particle", "purpose_particle", "comitative_particle", "initial_letters", "number", "unknown"]
    },
    "sarf": {
      "type": "object",
      "description": "Learner/reviewer-facing morphology state. This is the Fusha explanation layer, not a public provenance label.",
      "required": ["pos", "root", "pattern", "verb_form", "voice", "tense_aspect", "mood", "person", "number", "gender", "noun_number", "definiteness", "case", "derivative_type"],
      "additionalProperties": false,
      "properties": {
        "pos": { "type": "string", "enum": ["ism", "fiʿl", "ḥarf", "unknown"] },
        "root": { "type": ["string", "null"] },
        "pattern": { "type": ["string", "null"] },
        "verb_form": { "type": ["string", "null"] },
        "voice": { "type": ["string", "null"], "enum": ["active", "passive", "unknown", "not_applicable", "null"] },
        "tense_aspect": { "type": ["string", "null"], "enum": ["perfect", "imperfect", "imperative", "participle", "masdar", "not_applicable", "unknown", "null"] },
        "mood": { "type": ["string", "null"], "enum": ["indicative", "subjunctive", "jussive", "imperative", "not_applicable", "unknown", "null"] },
        "person": { "type": ["string", "null"], "enum": ["1", "2", "3", "not_applicable", "unknown", "null"] },
        "number": { "type": ["string", "null"], "enum": ["singular", "dual", "plural", "not_applicable", "unknown", "null"] },
        "gender": { "type": ["string", "null"], "enum": ["masculine", "feminine", "common", "none", "not_applicable", "unknown", "null"] },
        "noun_number": { "type": ["string", "null"], "enum": ["singular", "dual", "plural", "collective", "not_applicable", "unknown", "null"] },
        "definiteness": { "type": ["string", "null"], "enum": ["definite", "indefinite", "construct", "proper", "none", "not_applicable", "unknown", "null"] },
        "case": { "type": ["string", "null"], "enum": ["nominative", "accusative", "genitive", "jussive", "none", "not_applicable", "unknown", "null"] },
        "derivative_type": {
          "type": ["string", "null"],
          "enum": ["masdar", "ism_fail", "ism_mafool", "sifa_mushabbaha", "sighat_mubalaghah", "ism_tafdil", "ism_zaman_makan", "ism_ala", "proper_noun", "common_noun", "not_applicable", "unknown", "null"]
        }
      }
    },
    "nahw": {
      "type": "object",
      "description": "Learner/reviewer-facing syntax/function state that explains why the token means this here.",
      "required": ["function", "iʿrab_role", "governor", "governed_by", "pp_attachment", "idafa_relation", "pronoun_referent", "clause_relation", "reasoning_summary"],
      "additionalProperties": false,
      "properties": {
        "function": { "type": ["string", "null"] },
        "iʿrab_role": { "type": ["string", "null"] },
        "governor": { "type": ["string", "null"] },
        "governed_by": { "type": ["string", "null"] },
        "pp_attachment": { "type": ["string", "null"] },
        "idafa_relation": { "type": ["string", "null"] },
        "pronoun_referent": { "type": ["string", "null"] },
        "clause_relation": { "type": ["string", "null"] },
        "reasoning_summary": {
          "type": "string",
          "description": "Short source-clean reasoning. Use evidence sidecars for private source details."
        }
      }
    },
    "morphology": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verb_form": { "type": ["string", "null"], "description": "I-X, quadriliteral, or null." },
        "voice": { "type": ["string", "null"], "enum": ["active", "passive", "null"] },
        "aspect": { "type": ["string", "null"], "enum": ["perfect", "imperfect", "imperative", "participle", "masdar", "null"] },
        "mood": { "type": ["string", "null"], "enum": ["indicative", "subjunctive", "jussive", "imperative", "null"] },
        "case": { "type": ["string", "null"], "enum": ["nominative", "accusative", "genitive", "jussive", "none", "null"] },
        "state": { "type": ["string", "null"], "enum": ["definite", "indefinite", "construct", "proper", "none", "null"] },
        "person": { "type": ["string", "null"], "enum": ["1", "2", "3", "null"] },
        "number": { "type": ["string", "null"], "enum": ["singular", "dual", "plural", "null"] },
        "gender": { "type": ["string", "null"], "enum": ["masculine", "feminine", "common", "none", "null"] },
        "rationality": { "type": ["string", "null"], "enum": ["rational", "irrational", "none", "null"] },
        "semantic_gender": { "type": ["string", "null"], "enum": ["masculine", "feminine", "none", "null"] },
        "morphemic_gender": { "type": ["string", "null"], "enum": ["masculine", "feminine", "none", "null"] },
        "grammatical_gender": { "type": ["string", "null"], "enum": ["masculine", "feminine", "none", "null"] }
      }
    },
    "segments": {
      "type": "array",
      "description": "Token-internal pieces such as waw, fa, bi, inna, stem, subject pronoun, object pronoun, possessive pronoun.",
      "items": {
        "type": "object",
        "required": ["role", "surface"],
        "additionalProperties": false,
        "properties": {
          "role": {
            "type": "string",
            "enum": ["stem", "verb_prefix", "prefix_conjunction", "prefix_preposition", "prefix_oath", "prefix_comitative_waw", "prefix_resumption_fa", "prefix_coordination_fa", "prefix_result_fa", "prefix_supplemental_fa", "prefix_cause_fa", "prefix_interrogative_hamza", "prefix_equalization_hamza", "prefix_particle", "prefix_purpose_lam", "prefix_imperative_lam", "vocative_particle", "vocative_support", "attention_particle", "preventive_ma", "definite_article", "subject_pronoun", "object_pronoun", "possessive_pronoun", "relative_pronoun", "case_ending", "other"]
          },
          "surface": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^\\s]+$",
            "description": "Token-internal segment surface. Must be whitespace-free so renderers cannot encode spacing inside an Arabic word."
          },
          "gloss_contribution": { "type": ["string", "null"] },
          "person": { "type": ["string", "null"], "enum": ["1", "2", "3", "null"] },
          "number": { "type": ["string", "null"], "enum": ["singular", "dual", "plural", "null"] },
          "gender": { "type": ["string", "null"], "enum": ["masculine", "feminine", "common", "none", "null"] },
          "case": { "type": ["string", "null"], "enum": ["nominative", "accusative", "genitive", "none", "null"] }
        }
      }
    },
    "parse_key": {
      "type": "object",
      "description": "Scrubbed, renderer-ready parse key for the token. This is authored/internal grammar metadata, not public provenance and not copied source text.",
      "required": ["key", "summary", "components"],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "description": "Compact ASCII key such as V:III:PERF:ACT:3MP+OBJ.2MS or P:BI+N:GEN+POSS.3MP."
        },
        "summary": {
          "type": "string",
          "description": "Short human-readable parse summary for learner/reviewer tooltips."
        },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" },
              "note": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "display": {
      "type": "object",
      "description": "Stable color-role metadata for future Qamus hover rendering. Classes are semantic UI roles, not external source labels.",
      "required": ["palette", "segments"],
      "additionalProperties": false,
      "properties": {
        "palette": {
          "type": "string",
          "enum": ["qamus-grammar-v1"]
        },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["segment_index", "role", "class", "label"],
            "additionalProperties": false,
            "properties": {
              "segment_index": { "type": "integer" },
              "role": { "type": "string" },
              "class": {
                "type": "string",
                "enum": ["qg-article", "qg-case", "qg-comitative", "qg-exception", "qg-negative", "qg-noun", "qg-oath", "qg-particle", "qg-preposition", "qg-pronoun", "qg-proper-noun", "qg-relation", "qg-relative", "qg-result", "qg-unknown", "qg-verb", "qg-vocative"]
              },
              "label": {
                "type": "string",
                "description": "Short visible tag such as V, N, PRON, P, REL, ACC, PP, or VOC."
              }
            }
          }
        }
      }
    },
    "syntax": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "role": { "type": ["string", "null"], "description": "subject, object, khabar, tamyiz, badal, sifa, mudaf, mudaf_ilayh, etc." },
        "governor": { "type": ["string", "null"], "description": "loc of governing token when known." },
        "head": { "type": ["string", "null"], "description": "loc of head token in a dependency relation." },
        "dependency": {
          "type": ["string", "null"],
          "enum": ["subject", "hidden_subject", "naib_fail", "object", "first_object", "second_object", "jar_majrur", "preposition_phrase", "pp_attachment", "pp_attached_to_verb", "pp_attached_to_nominal", "pp_attached_to_hidden_hal", "pp_attached_to_hidden_sifa", "oath_preposition", "idafa_head", "idafa_dependent", "sifa", "badal", "tamyiz", "murakkab", "hal", "hal_from_pronoun", "interrogative_hal", "mafool_mutlaq", "mafool_liajlih", "mafool_maahu", "coordination", "coordinated", "condition", "temporal_condition", "answer_of_condition", "relative_clause", "subordinate_clause", "purpose_clause", "interrogative", "equalization", "vocative", "vocative_addressee", "exceptive", "mustathna_minhu", "mustathna", "khabar", "ism_kana", "khabar_kana", "ism_kada", "khabar_kada", "ism_inna", "khabar_inna", "la_anna_subject", "la_anna_predicate", "kafa_makfufa", "ism_ma_laysa", "khabar_ma_laysa", "subjunctive_governor", "jussive_governor", "negation", "resumption", "result_fa", "supplemental", "cause_fa", "imperative", "imperative_lam", "prohibition", "jawab_amr", "null"]
        },
        "phrase_type": { "type": ["string", "null"], "enum": ["PP", "VS", "NS", "SC", "none", "null"] },
        "attachment_target_kind": { "type": ["string", "null"], "enum": ["verb", "nominal", "pronoun", "hidden_hal", "hidden_sifa", "clause", "cross_verse_pronoun", "none", "null"] },
        "clause_kind": { "type": ["string", "null"], "enum": ["relative", "subordinate", "purpose", "condition", "answer_of_condition", "none", "null"] },
        "condition_kind": { "type": ["string", "null"], "enum": ["temporal", "conditional_particle", "none", "null"] },
        "exception_kind": { "type": ["string", "null"], "enum": ["muttasil", "munqati", "mufarragh", "none", "null"] },
        "linked_locs": { "type": "array", "items": { "type": "string", "pattern": "^\\d{1,3}:\\d{1,3}:\\d{1,3}$" } }
      }
    },
    "hover_contract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "must_surface": { "type": "array", "items": { "type": "string" } },
        "must_not_surface": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": ["string", "null"] }
      }
    },
    "learner_explanation": {
      "type": "string",
      "minLength": 1,
      "description": "Source-clean sentence explaining what the visible Arabic pieces contribute. It must not merely restate the English gloss."
    },
    "blocker": {
      "type": ["string", "null"],
      "description": "Exact pending or blocked reason. Null only when the row is not pending/blocked."
    },
    "evidence": {
      "type": "object",
      "required": ["labels"],
      "additionalProperties": false,
      "properties": {
        "labels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Internal evidence labels such as tafsir-center:analyze_word:S:A:W:irab_sarf; never public."
        },
        "gate": {
          "type": "string",
          "enum": ["auto_safe", "two_vote_required", "human_source_review_required", "never_auto_resolve"]
        },
        "reasoning": { "type": ["string", "null"] }
      }
    },
    "public_boundary": {
      "type": "object",
      "required": ["public_gloss_src", "public_gloss_kind", "public_gloss_lang", "external_source_names_public"],
      "additionalProperties": false,
      "properties": {
        "public_gloss_src": { "const": "qamus" },
        "public_gloss_kind": { "const": "authored" },
        "public_gloss_lang": { "const": "en" },
        "external_source_names_public": { "const": false }
      }
    }
  }
}
