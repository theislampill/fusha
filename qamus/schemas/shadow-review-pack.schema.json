{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/shadow-review-pack.schema.json",
  "title": "Qamus live shadow graph review-pack row",
  "type": "object",
  "required": [
    "id",
    "parse_id",
    "lane",
    "scope",
    "recommended_action",
    "required_gate",
    "family_size",
    "resolved_token_count",
    "unresolved_token_count",
    "quran_locs",
    "wbw_locs",
    "token_sample",
    "candidate_entries",
    "candidate_join_statuses",
    "parse",
    "apply_policy"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^queue:parse_"
    },
    "parse_id": {
      "type": "string",
      "pattern": "^parse:[0-9a-f]+$"
    },
    "lane": {
      "type": "string",
      "pattern": "^(blocked:[a-z0-9_]+|human_review_required|quarantine_collision|two_vote_required|missing_entry|unknown_parse|propagation_safe_candidate|token_only_required)$"
    },
    "scope": {
      "type": "string"
    },
    "recommended_action": {
      "type": "string",
      "minLength": 1
    },
    "required_gate": {
      "type": "string",
      "minLength": 1
    },
    "family_size": {
      "type": "integer",
      "minimum": 1
    },
    "resolved_token_count": {
      "type": "integer",
      "minimum": 0
    },
    "unresolved_token_count": {
      "type": "integer",
      "minimum": 0
    },
    "surface_sample": {
      "type": "string"
    },
    "quran_locs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^quran:\\d{1,3}:\\d{1,3}:\\d{1,3}$"
      }
    },
    "wbw_locs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^wbw:\\d{1,3}:\\d{1,3}:\\d{1,3}$"
      }
    },
    "token_sample": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^quran:\\d{1,3}:\\d{1,3}:\\d{1,3}$"
      }
    },
    "candidate_entries": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^qamus:"
      }
    },
    "candidate_join_statuses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry", "join_status"],
        "additionalProperties": false,
        "properties": {
          "entry": {
            "type": "string",
            "pattern": "^qamus:"
          },
          "join_status": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "parse": {
      "type": "object",
      "required": [
        "gate",
        "blocker",
        "decision_status",
        "parse_confidence",
        "pos",
        "root",
        "lemma",
        "particle_function",
        "grammar_triggers"
      ],
      "additionalProperties": false,
      "properties": {
        "gate": {
          "type": ["string", "null"]
        },
        "blocker": {
          "type": ["string", "null"]
        },
        "decision_status": {
          "type": ["string", "null"]
        },
        "parse_confidence": {
          "type": ["string", "null"]
        },
        "pos": {
          "type": ["string", "null"]
        },
        "root": {
          "type": ["string", "null"]
        },
        "lemma": {
          "type": ["string", "null"]
        },
        "particle_function": {
          "type": ["string", "null"]
        },
        "grammar_triggers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "apply_policy": {
      "type": "object",
      "required": ["live_mutation_allowed", "identity", "public_boundary", "detector_maturity"],
      "additionalProperties": false,
      "properties": {
        "live_mutation_allowed": {
          "const": false
        },
        "identity": {
          "type": "string",
          "pattern": "quran:S:A:W"
        },
        "public_boundary": {
          "const": "src=qamus, kind=authored, lang=en; no external provenance"
        },
        "detector_maturity": {
          "$ref": "detector-maturity.schema.json#/properties/detectors"
        }
      }
    }
  }
}
