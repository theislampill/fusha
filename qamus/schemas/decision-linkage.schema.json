{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/decision-linkage.schema.json",
  "title": "Qamus hover decision linkage",
  "type": "object",
  "required": ["decision_id", "quran_loc", "wbw_loc", "parse_id", "gate", "status", "public_boundary"],
  "additionalProperties": false,
  "properties": {
    "decision_id": { "type": "string", "pattern": "^decision:" },
    "quran_loc": { "type": "string", "pattern": "^quran:\\d{1,3}:\\d{1,3}:\\d{1,3}$" },
    "wbw_loc": { "type": "string", "pattern": "^wbw:\\d{1,3}:\\d{1,3}:\\d{1,3}$" },
    "parse_id": { "type": "string", "pattern": "^parse:[0-9a-f]+$" },
    "entry_sense": { "type": ["string", "null"], "pattern": "^qamus:.+#sense=\\d+$" },
    "blocker": { "type": ["string", "null"], "pattern": "^blocker:" },
    "gate": {
      "type": "string",
      "enum": ["auto_safe", "token_review", "auto_safe_after_preview", "two_vote_required", "human_review_required", "owner_review_required", "never_auto", "unknown"]
    },
    "status": { "type": "string", "enum": ["resolved", "pending", "blocked", "superseded"] },
    "internal_evidence": { "type": "array", "items": { "type": "string" } },
    "public_boundary": { "$ref": "public-private-boundary.schema.json" }
  }
}
