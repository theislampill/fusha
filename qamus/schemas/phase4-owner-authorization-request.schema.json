{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/phase4-owner-authorization-request.schema.json",
  "title": "Qamus Phase 4 source-only owner authorization request",
  "type": "object",
  "required": [
    "id",
    "phase",
    "status",
    "generated_by",
    "source_artifacts",
    "owner_authorization",
    "apply_policy",
    "public_boundary",
    "required_before_live_apply",
    "sample_decisions"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^phase4-owner-authorization-request:[0-9a-f]{16}$"
    },
    "phase": {
      "const": "phase4_owner_authorization_request"
    },
    "status": {
      "const": "owner_review_required_not_authorized"
    },
    "generated_by": {
      "const": "tools/build_phase4_owner_authorization_request.py"
    },
    "source_artifacts": {
      "type": "object",
      "required": [
        "apply_readiness_manifest",
        "draft_token_decision_ledger"
      ],
      "additionalProperties": false,
      "properties": {
        "apply_readiness_manifest": {
          "type": "object",
          "required": [
            "artifact",
            "sha256",
            "id",
            "status"
          ],
          "additionalProperties": false,
          "properties": {
            "artifact": {
              "type": "string",
              "minLength": 1,
              "not": {
                "pattern": "[/\\\\]"
              }
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "id": {
              "type": "string",
              "pattern": "^phase4-apply-readiness:[0-9a-f]{16}$"
            },
            "status": {
              "const": "pre_apply_not_authorized"
            }
          }
        },
        "draft_token_decision_ledger": {
          "type": "object",
          "required": [
            "artifact",
            "sha256",
            "row_count",
            "decision_id_count",
            "quran_loc_count",
            "wbw_loc_count"
          ],
          "additionalProperties": false,
          "properties": {
            "artifact": {
              "type": "string",
              "minLength": 1,
              "not": {
                "pattern": "[/\\\\]"
              }
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "row_count": {
              "type": "integer",
              "minimum": 1
            },
            "decision_id_count": {
              "type": "integer",
              "minimum": 1
            },
            "quran_loc_count": {
              "type": "integer",
              "minimum": 1
            },
            "wbw_loc_count": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "owner_authorization": {
      "type": "object",
      "required": [
        "required",
        "status",
        "authorized_by",
        "authorized_at",
        "authorized_scope"
      ],
      "additionalProperties": false,
      "properties": {
        "required": {
          "const": true
        },
        "status": {
          "const": "not_provided"
        },
        "authorized_by": {
          "type": "null"
        },
        "authorized_at": {
          "type": "null"
        },
        "authorized_scope": {
          "const": "none"
        }
      }
    },
    "apply_policy": {
      "type": "object",
      "required": [
        "source_only",
        "owner_authorization_required",
        "apply_allowed",
        "live_mutation_allowed",
        "wbw_rebuild_allowed",
        "service_restart_allowed",
        "mirror_sync_allowed",
        "closure_claim_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "source_only": {
          "const": true
        },
        "owner_authorization_required": {
          "const": true
        },
        "apply_allowed": {
          "const": false
        },
        "live_mutation_allowed": {
          "const": false
        },
        "wbw_rebuild_allowed": {
          "const": false
        },
        "service_restart_allowed": {
          "const": false
        },
        "mirror_sync_allowed": {
          "const": false
        },
        "closure_claim_allowed": {
          "const": false
        }
      }
    },
    "public_boundary": {
      "type": "object",
      "required": [
        "src",
        "kind",
        "lang",
        "external_source_names_public",
        "internal_provenance_public"
      ],
      "additionalProperties": false,
      "properties": {
        "src": {
          "const": "qamus"
        },
        "kind": {
          "const": "authored"
        },
        "lang": {
          "const": "en"
        },
        "external_source_names_public": {
          "const": false
        },
        "internal_provenance_public": {
          "const": false
        }
      }
    },
    "required_before_live_apply": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sample_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "identity",
          "token_decision",
          "safe_scope"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^phase4-draft-token-decision:\\d{1,3}_\\d{1,3}_\\d{1,3}:[0-9a-f]+$"
          },
          "identity": {
            "type": "object"
          },
          "token_decision": {
            "type": "object",
            "required": [
              "loc",
              "gloss",
              "src",
              "kind",
              "lang"
            ],
            "additionalProperties": false,
            "properties": {
              "loc": {
                "type": "string",
                "pattern": "^\\d{1,3}:\\d{1,3}:\\d{1,3}$"
              },
              "gloss": {
                "type": "string",
                "minLength": 1
              },
              "src": {
                "const": "qamus"
              },
              "kind": {
                "const": "authored"
              },
              "lang": {
                "const": "en"
              }
            }
          },
          "safe_scope": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
