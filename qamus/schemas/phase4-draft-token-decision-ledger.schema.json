{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/phase4-draft-token-decision-ledger.schema.json",
  "title": "Qamus Phase 4 source-only draft token-decision ledger row",
  "type": "object",
  "required": [
    "id",
    "phase",
    "status",
    "identity",
    "token_decision",
    "plan_lineage",
    "safe_scope",
    "public_boundary",
    "apply_policy"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^phase4-draft-token-decision:\\d{1,3}_\\d{1,3}_\\d{1,3}:[0-9a-f]+$"
    },
    "phase": {
      "const": "phase4_draft_token_decision_ledger"
    },
    "status": {
      "const": "draft_not_applied"
    },
    "identity": {
      "type": "object",
      "required": [
        "quran_loc",
        "wbw_loc",
        "parse_id",
        "surface_sample"
      ],
      "additionalProperties": false,
      "properties": {
        "quran_loc": {
          "type": "string",
          "pattern": "^quran:\\d{1,3}:\\d{1,3}:\\d{1,3}$"
        },
        "wbw_loc": {
          "type": "string",
          "pattern": "^wbw:\\d{1,3}:\\d{1,3}:\\d{1,3}$"
        },
        "parse_id": {
          "type": "string",
          "pattern": "^parse:[0-9a-f]+$"
        },
        "surface_sample": {
          "type": "string"
        }
      }
    },
    "token_decision": {
      "type": "object",
      "required": [
        "loc",
        "gloss",
        "src",
        "kind",
        "lang"
      ],
      "additionalProperties": false,
      "properties": {
        "loc": {
          "type": "string",
          "pattern": "^\\d{1,3}:\\d{1,3}:\\d{1,3}$"
        },
        "gloss": {
          "type": "string",
          "minLength": 1
        },
        "src": {
          "const": "qamus"
        },
        "kind": {
          "const": "authored"
        },
        "lang": {
          "const": "en"
        }
      }
    },
    "plan_lineage": {
      "type": "object",
      "required": [
        "source_plan_id",
        "source_phase",
        "source_certified_id",
        "source_certified_ids",
        "reason_agreement_key"
      ],
      "additionalProperties": false,
      "properties": {
        "source_plan_id": {
          "type": "string",
          "pattern": "^phase4-hover-decision-plan:\\d{1,3}_\\d{1,3}_\\d{1,3}:[0-9a-f]+$"
        },
        "source_phase": {
          "enum": [
            "phase4_two_vote_reconciled",
            "phase4_gloss_adjudication_reconciled"
          ]
        },
        "source_certified_id": {
          "type": "string",
          "minLength": 1
        },
        "source_certified_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reason_agreement_key": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "safe_scope": {
      "enum": [
        "token_only",
        "parse_family_after_impact_preview",
        "pending"
      ]
    },
    "public_boundary": {
      "type": "object",
      "required": [
        "src",
        "kind",
        "lang",
        "internal_provenance_public",
        "external_source_names_public"
      ],
      "additionalProperties": false,
      "properties": {
        "src": {
          "const": "qamus"
        },
        "kind": {
          "const": "authored"
        },
        "lang": {
          "const": "en"
        },
        "internal_provenance_public": {
          "const": false
        },
        "external_source_names_public": {
          "const": false
        }
      }
    },
    "apply_policy": {
      "type": "object",
      "required": [
        "draft_only",
        "apply_allowed",
        "live_mutation_allowed",
        "closure_claim_allowed",
        "append_only_ledger_required",
        "backup_required",
        "rebuild_required",
        "validation_required",
        "health_check_required",
        "targeted_public_readback_required",
        "public_boundary_scan_required",
        "rollback_required",
        "component_candidates_can_certify",
        "raw_surface_identity_allowed",
        "parse_key_primary_identity"
      ],
      "additionalProperties": false,
      "properties": {
        "draft_only": {
          "const": true
        },
        "apply_allowed": {
          "const": false
        },
        "live_mutation_allowed": {
          "const": false
        },
        "closure_claim_allowed": {
          "const": false
        },
        "append_only_ledger_required": {
          "const": true
        },
        "backup_required": {
          "const": true
        },
        "rebuild_required": {
          "const": true
        },
        "validation_required": {
          "const": true
        },
        "health_check_required": {
          "const": true
        },
        "targeted_public_readback_required": {
          "const": true
        },
        "public_boundary_scan_required": {
          "const": true
        },
        "rollback_required": {
          "const": true
        },
        "component_candidates_can_certify": {
          "const": false
        },
        "raw_surface_identity_allowed": {
          "const": false
        },
        "parse_key_primary_identity": {
          "const": false
        }
      }
    }
  }
}
