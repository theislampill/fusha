{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/phase4-gloss-adjudication-request.schema.json",
  "title": "Qamus Phase 4 gloss wording adjudication request row",
  "type": "object",
  "required": [
    "id",
    "phase",
    "source_two_vote_request_id",
    "source_unresolved_reason",
    "parse_id",
    "identity",
    "candidate_glosses",
    "shared_reason_agreement_key",
    "vote_summaries",
    "allowed_next_step",
    "requested_output",
    "public_boundary",
    "apply_policy"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^phase4-gloss-adjudication:queue_parse_[0-9a-f]+$"
    },
    "phase": {
      "const": "phase4_gloss_adjudication_request"
    },
    "source_two_vote_request_id": {
      "type": "string",
      "pattern": "^phase4-two-vote:queue_parse_[0-9a-f]+$"
    },
    "source_unresolved_reason": {
      "const": "gloss_wording_disagreement"
    },
    "parse_id": {
      "type": "string",
      "pattern": "^parse:[0-9a-f]+$"
    },
    "identity": {
      "type": "object",
      "required": ["quran_locs", "wbw_locs", "parse_id", "surface_sample"],
      "additionalProperties": false,
      "properties": {
        "quran_locs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^quran:\\d{1,3}:\\d{1,3}:\\d{1,3}$"
          }
        },
        "wbw_locs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^wbw:\\d{1,3}:\\d{1,3}:\\d{1,3}$"
          }
        },
        "parse_id": {
          "type": "string",
          "pattern": "^parse:[0-9a-f]+$"
        },
        "surface_sample": {
          "type": "string"
        }
      }
    },
    "candidate_glosses": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "shared_reason_agreement_key": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9-]+$"
    },
    "vote_summaries": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object"
      }
    },
    "allowed_next_step": {
      "const": "owner_or_scholar_gloss_adjudication_only"
    },
    "requested_output": {
      "type": "object",
      "required": ["selected_concise_authored_gloss", "adjudication_reason", "safe_scope_after_adjudication"],
      "additionalProperties": false,
      "properties": {
        "selected_concise_authored_gloss": {
          "const": ""
        },
        "adjudication_reason": {
          "const": ""
        },
        "safe_scope_after_adjudication": {
          "const": "token_only | parse_family_after_impact_preview | pending"
        }
      }
    },
    "public_boundary": {
      "type": "object"
    },
    "apply_policy": {
      "type": "object"
    }
  }
}
