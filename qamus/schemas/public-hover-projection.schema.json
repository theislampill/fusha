{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/public-hover-projection.schema.json",
  "title": "Qamus public-safe hover projection",
  "type": "object",
  "required": ["schema", "row_id", "entry_id", "card_id", "surface", "canonical_quran_loc", "canonical_wbw_loc", "src", "kind", "lang", "public_gloss", "token_contribution", "segments", "qg_classes", "public_boundary", "live_mutation_allowed"],
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "qamus/public-hover-projection@1" },
    "row_id": { "type": "string", "minLength": 1 },
    "entry_id": { "type": "string", "minLength": 1 },
    "card_id": { "type": "string", "minLength": 1 },
    "surface": { "type": "string", "minLength": 1 },
    "canonical_quran_loc": { "type": "string", "pattern": "^\\d{1,3}:\\d{1,3}:\\d{1,3}$" },
    "canonical_wbw_loc": { "type": "string", "pattern": "^\\d{1,3}:\\d{1,3}:\\d{1,3}$" },
    "src": { "const": "qamus" },
    "kind": { "const": "authored" },
    "lang": { "const": "en" },
    "public_gloss": { "type": "string", "minLength": 1 },
    "token_contribution": { "type": "string", "minLength": 1 },
    "segments": { "type": "array", "items": { "type": "object" }, "minItems": 1 },
    "qg_classes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "public_boundary": { "$ref": "public-private-boundary.schema.json" },
    "live_mutation_allowed": { "const": false }
  }
}
