{
  "$defs": {
    "address_type": {
      "enum": [
        "quran_loc",
        "wbw_loc",
        "parse_id",
        "qamus_entry",
        "qamus_field",
        "entry_sense",
        "decision_id",
        "blocker_id",
        "repair_preview_id",
        "edit_intent_id"
      ],
      "type": "string"
    },
    "route": {
      "additionalProperties": false,
      "properties": {
        "admin_only": {
          "const": true
        },
        "auth_required": {
          "const": true
        },
        "input_address_types": {
          "items": {
            "$ref": "#/$defs/address_type"
          },
          "type": "array",
          "uniqueItems": true
        },
        "live_mutation_allowed": {
          "const": false
        },
        "method": {
          "const": "GET"
        },
        "output_pack_fields": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "path_template": {
          "pattern": "^/admin/qamus/shadow/",
          "type": "string"
        },
        "private_debug_allowed": {
          "const": true
        },
        "public_exposable": {
          "const": false
        },
        "public_payload_allowed": {
          "const": false
        },
        "read_only": {
          "const": true
        },
        "route_id": {
          "pattern": "^route:",
          "type": "string"
        },
        "view": {
          "$ref": "#/$defs/view"
        }
      },
      "required": [
        "route_id",
        "view",
        "method",
        "path_template",
        "admin_only",
        "auth_required",
        "read_only",
        "public_exposable",
        "live_mutation_allowed",
        "input_address_types",
        "output_pack_fields",
        "private_debug_allowed",
        "public_payload_allowed"
      ],
      "type": "object"
    },
    "view": {
      "enum": [
        "hover_inspector",
        "entry_backlinks",
        "parse_family_view",
        "blocker_queue",
        "repair_preview",
        "edit_intent_preview",
        "rich_hover_preview"
      ],
      "type": "string"
    }
  },
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/shadow-admin-route-contract.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "admin_only": {
      "const": true
    },
    "identity_policy": {
      "additionalProperties": false,
      "properties": {
        "exact_token_identity_required": {
          "const": true
        },
        "norm_only_certification_allowed": {
          "const": false
        },
        "parse_key_primary_identity": {
          "const": false
        },
        "raw_surface_identity_allowed": {
          "const": false
        }
      },
      "required": [
        "exact_token_identity_required",
        "raw_surface_identity_allowed",
        "parse_key_primary_identity",
        "norm_only_certification_allowed"
      ],
      "type": "object"
    },
    "live_mutation_allowed": {
      "const": false
    },
    "public_boundary": {
      "$ref": "public-private-boundary.schema.json"
    },
    "public_exposable": {
      "const": false
    },
    "requires_auth": {
      "const": true
    },
    "route_defaults": {
      "additionalProperties": false,
      "properties": {
        "allowed_methods": {
          "items": {
            "const": "GET"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "apply_routes_allowed": {
          "const": false
        },
        "mutating_methods_allowed": {
          "const": false
        },
        "source_pack_required": {
          "const": true
        }
      },
      "required": [
        "allowed_methods",
        "mutating_methods_allowed",
        "apply_routes_allowed",
        "source_pack_required"
      ],
      "type": "object"
    },
    "route_surface": {
      "const": "read_only_admin_debug"
    },
    "routes": {
      "items": {
        "$ref": "#/$defs/route"
      },
      "minItems": 5,
      "type": "array"
    },
    "source_pack_contract": {
      "additionalProperties": false,
      "properties": {
        "accepts_dirty_mirror_repo": {
          "const": false
        },
        "accepts_live_paths": {
          "const": false
        },
        "accepts_public_webroot_paths": {
          "const": false
        },
        "allowed_pack_roots": {
          "items": {
            "enum": [
              "out/",
              "qamus/examples/"
            ],
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "artifact_type": {
          "const": "shadow_admin_debug_pack"
        },
        "requires_validated_pack": {
          "const": true
        },
        "route_reads_only": {
          "const": true
        },
        "version": {
          "const": "qamus-shadow-admin-debug-pack@1"
        }
      },
      "required": [
        "artifact_type",
        "version",
        "requires_validated_pack",
        "accepts_live_paths",
        "accepts_public_webroot_paths",
        "accepts_dirty_mirror_repo",
        "route_reads_only",
        "allowed_pack_roots"
      ],
      "type": "object"
    },
    "source_pack_version": {
      "const": "qamus-shadow-admin-debug-pack@1"
    },
    "version": {
      "const": "qamus-shadow-admin-route-contract@1"
    }
  },
  "required": [
    "version",
    "source_pack_version",
    "route_surface",
    "public_exposable",
    "live_mutation_allowed",
    "requires_auth",
    "admin_only",
    "source_pack_contract",
    "identity_policy",
    "route_defaults",
    "routes",
    "public_boundary"
  ],
  "title": "Qamus shadow admin route contract",
  "type": "object"
}
