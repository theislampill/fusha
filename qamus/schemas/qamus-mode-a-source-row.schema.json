{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/qamus-mode-a-source-row.schema.json",
  "title": "Qamus Mode A source-addressed visible qword row",
  "type": "object",
  "required": ["schema", "row_id", "smoke_case", "entry_id", "sense_index", "example_card_index", "card_id", "card_text", "displayed_surface", "qword_index", "canonical_quran_loc", "canonical_wbw_loc", "source_key"],
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "qamus/mode-a-source-row@1" },
    "row_id": { "type": "string", "minLength": 1 },
    "smoke_case": { "type": "string", "minLength": 1 },
    "entry_id": { "type": "string", "minLength": 1 },
    "sense_index": { "type": "integer", "minimum": 1 },
    "example_card_index": { "type": "integer", "minimum": 1 },
    "card_id": { "type": "string", "minLength": 1 },
    "card_text": { "type": "string", "minLength": 1 },
    "displayed_surface": { "type": "string", "minLength": 1 },
    "qword_index": { "type": "integer", "minimum": 1 },
    "canonical_quran_loc": { "type": "string", "pattern": "^\\d{1,3}:\\d{1,3}:\\d{1,3}$" },
    "canonical_wbw_loc": { "type": "string", "pattern": "^\\d{1,3}:\\d{1,3}:\\d{1,3}$" },
    "display_local_loc": { "type": ["string", "null"] },
    "source_address_crosswalk": { "type": ["object", "null"] },
    "source_key": { "type": "string", "minLength": 1 },
    "card_expected_qword_count": { "type": ["integer", "null"], "minimum": 1 },
    "vocalization_required": { "type": "boolean" },
    "card_vocalization_required": { "type": "boolean" }
  }
}
