{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/phase4-apply-readiness-manifest.schema.json",
  "title": "Qamus Phase 4 apply-readiness manifest",
  "type": "object",
  "required": [
    "id",
    "phase",
    "status",
    "generated_by",
    "source_plan",
    "truth_owners",
    "apply_policy",
    "public_boundary",
    "required_gates",
    "abort_conditions",
    "rollback",
    "sample_tokens"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^phase4-apply-readiness:[0-9a-f]{16}$"
    },
    "phase": {
      "const": "phase4_apply_readiness_manifest"
    },
    "status": {
      "const": "pre_apply_not_authorized"
    },
    "generated_by": {
      "const": "tools/build_phase4_apply_readiness_manifest.py"
    },
    "source_plan": {
      "type": "object",
      "required": [
        "artifact",
        "sha256",
        "row_count",
        "plan_id_count",
        "quran_loc_count",
        "wbw_loc_count",
        "parse_id_count"
      ],
      "additionalProperties": false,
      "properties": {
        "artifact": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "[/\\\\]"
          }
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "row_count": {
          "type": "integer",
          "minimum": 1
        },
        "plan_id_count": {
          "type": "integer",
          "minimum": 1
        },
        "quran_loc_count": {
          "type": "integer",
          "minimum": 1
        },
        "wbw_loc_count": {
          "type": "integer",
          "minimum": 1
        },
        "parse_id_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "truth_owners": {
      "type": "object",
      "required": [
        "hover_decision_plan",
        "live_wbw_lookup",
        "live_entries",
        "token_decision_ledger",
        "public_render"
      ],
      "additionalProperties": false,
      "properties": {
        "hover_decision_plan": {
          "type": "string",
          "minLength": 1
        },
        "live_wbw_lookup": {
          "type": "string",
          "minLength": 1
        },
        "live_entries": {
          "type": "string",
          "minLength": 1
        },
        "token_decision_ledger": {
          "type": "string",
          "minLength": 1
        },
        "public_render": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "apply_policy": {
      "type": "object",
      "required": [
        "apply_authorized",
        "apply_allowed",
        "live_mutation_allowed",
        "wbw_rebuild_allowed",
        "service_restart_allowed",
        "mirror_sync_allowed",
        "closure_claim_allowed",
        "parse_key_primary_identity",
        "raw_surface_identity_allowed",
        "component_candidates_can_certify",
        "decision_plan_only"
      ],
      "additionalProperties": false,
      "properties": {
        "apply_authorized": {
          "const": false
        },
        "apply_allowed": {
          "const": false
        },
        "live_mutation_allowed": {
          "const": false
        },
        "wbw_rebuild_allowed": {
          "const": false
        },
        "service_restart_allowed": {
          "const": false
        },
        "mirror_sync_allowed": {
          "const": false
        },
        "closure_claim_allowed": {
          "const": false
        },
        "parse_key_primary_identity": {
          "const": false
        },
        "raw_surface_identity_allowed": {
          "const": false
        },
        "component_candidates_can_certify": {
          "const": false
        },
        "decision_plan_only": {
          "const": true
        }
      }
    },
    "public_boundary": {
      "type": "object",
      "required": [
        "src",
        "kind",
        "lang",
        "external_source_names_public",
        "internal_provenance_public"
      ],
      "additionalProperties": false,
      "properties": {
        "src": {
          "const": "qamus"
        },
        "kind": {
          "const": "authored"
        },
        "lang": {
          "const": "en"
        },
        "external_source_names_public": {
          "const": false
        },
        "internal_provenance_public": {
          "const": false
        }
      }
    },
    "required_gates": {
      "type": "object",
      "required": [
        "append_only_ledger",
        "backup",
        "rebuild",
        "validation",
        "health_check",
        "targeted_public_readback",
        "public_boundary_scan",
        "rollback_rehearsal"
      ],
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": [
            "required",
            "status",
            "evidence_required"
          ],
          "additionalProperties": false,
          "properties": {
            "required": {
              "const": true
            },
            "status": {
              "const": "not_run"
            },
            "evidence_required": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "abort_conditions": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback": {
      "type": "object",
      "required": [
        "required",
        "strategy",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "required": {
          "const": true
        },
        "strategy": {
          "const": "append_only_revert_or_restore_backup"
        },
        "status": {
          "const": "not_run"
        }
      }
    },
    "excluded_tranche_rows": {
      "type": "object",
      "required": [
        "source_tranche",
        "excluded_count",
        "excluded_by_lane",
        "excluded_by_gate",
        "sample_excluded"
      ],
      "additionalProperties": false,
      "properties": {
        "source_tranche": {
          "type": "object",
          "required": [
            "artifact",
            "sha256",
            "row_count"
          ],
          "additionalProperties": false,
          "properties": {
            "artifact": {
              "type": "string",
              "minLength": 1,
              "not": {
                "pattern": "[/\\\\]"
              }
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "row_count": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "excluded_count": {
          "type": "integer",
          "minimum": 0
        },
        "excluded_by_lane": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 1
          }
        },
        "excluded_by_gate": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 1
          }
        },
        "sample_excluded": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "parse_id",
              "surface_sample",
              "quran_locs",
              "wbw_locs",
              "lane",
              "required_gate",
              "recommended_action"
            ],
            "additionalProperties": false,
            "properties": {
              "parse_id": {
                "type": "string",
                "pattern": "^parse:[0-9a-f]+$"
              },
              "surface_sample": {
                "type": "string"
              },
              "quran_locs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^quran:\\d{1,3}:\\d{1,3}:\\d{1,3}$"
                }
              },
              "wbw_locs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^wbw:\\d{1,3}:\\d{1,3}:\\d{1,3}$"
                }
              },
              "lane": {
                "type": "string",
                "minLength": 1
              },
              "required_gate": {
                "type": "string",
                "minLength": 1
              },
              "recommended_action": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "sample_tokens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "plan_id",
          "quran_loc",
          "wbw_loc",
          "parse_id",
          "surface_sample",
          "public_hover"
        ],
        "additionalProperties": false,
        "properties": {
          "plan_id": {
            "type": "string",
            "minLength": 1
          },
          "quran_loc": {
            "type": "string",
            "pattern": "^quran:\\d{1,3}:\\d{1,3}:\\d{1,3}$"
          },
          "wbw_loc": {
            "type": "string",
            "pattern": "^wbw:\\d{1,3}:\\d{1,3}:\\d{1,3}$"
          },
          "parse_id": {
            "type": "string",
            "pattern": "^parse:[0-9a-f]+$"
          },
          "surface_sample": {
            "type": "string"
          },
          "public_hover": {
            "type": "object",
            "required": [
              "gloss",
              "src",
              "kind",
              "lang"
            ],
            "additionalProperties": false,
            "properties": {
              "gloss": {
                "type": "string",
                "minLength": 1
              },
              "src": {
                "const": "qamus"
              },
              "kind": {
                "const": "authored"
              },
              "lang": {
                "const": "en"
              }
            }
          }
        }
      }
    }
  }
}
