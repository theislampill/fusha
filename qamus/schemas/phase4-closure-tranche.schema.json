{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theIslampill/fusha/qamus/schemas/phase4-closure-tranche.schema.json",
  "title": "Qamus Phase 4 dry-run closure tranche row",
  "type": "object",
  "required": [
    "id",
    "phase",
    "source_review_pack_id",
    "parse_id",
    "lane",
    "priority",
    "allowed_next_step",
    "scope",
    "recommended_action",
    "required_gate",
    "required_evidence",
    "impact_preview_required",
    "identity",
    "candidate_evidence",
    "gate_reasons",
    "apply_policy"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^phase4-tranche:queue_parse_"
    },
    "phase": {
      "const": "phase4_dry_run"
    },
    "source_review_pack_id": {
      "type": "string",
      "pattern": "^queue:parse_"
    },
    "parse_id": {
      "type": "string",
      "pattern": "^parse:[0-9a-f]+$"
    },
    "lane": {
      "type": "string"
    },
    "priority": {
      "type": "integer",
      "minimum": 1
    },
    "allowed_next_step": {
      "const": "review_only"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "recommended_action": {
      "type": "string",
      "minLength": 1
    },
    "required_gate": {
      "type": "string",
      "minLength": 1
    },
    "required_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "impact_preview_required": {
      "const": true
    },
    "identity": {
      "type": "object",
      "required": ["quran_locs", "wbw_locs", "parse_id", "surface_sample"],
      "additionalProperties": false,
      "properties": {
        "quran_locs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^quran:\\d{1,3}:\\d{1,3}:\\d{1,3}$"
          }
        },
        "wbw_locs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^wbw:\\d{1,3}:\\d{1,3}:\\d{1,3}$"
          }
        },
        "parse_id": {
          "type": "string",
          "pattern": "^parse:[0-9a-f]+$"
        },
        "surface_sample": {
          "type": "string"
        }
      }
    },
    "candidate_evidence": {
      "type": "object",
      "required": [
        "whole_token_candidates",
        "whole_token_candidate_joins",
        "component_candidates",
        "component_candidate_joins"
      ],
      "additionalProperties": false,
      "properties": {
        "whole_token_candidates": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^qamus:"
          }
        },
        "whole_token_candidate_joins": {
          "type": "array"
        },
        "component_candidates": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^qamus:"
          }
        },
        "component_candidate_joins": {
          "type": "array"
        }
      }
    },
    "gate_reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "apply_policy": {
      "type": "object",
      "required": [
        "apply_allowed",
        "live_mutation_allowed",
        "closure_claim_allowed",
        "identity",
        "public_boundary",
        "component_candidates_can_certify",
        "raw_surface_identity_allowed",
        "parse_key_primary_identity"
      ],
      "additionalProperties": false,
      "properties": {
        "apply_allowed": {
          "const": false
        },
        "live_mutation_allowed": {
          "const": false
        },
        "closure_claim_allowed": {
          "const": false
        },
        "identity": {
          "type": "string",
          "pattern": "quran:S:A:W"
        },
        "public_boundary": {
          "const": "src=qamus, kind=authored, lang=en; no external provenance"
        },
        "component_candidates_can_certify": {
          "const": false
        },
        "raw_surface_identity_allowed": {
          "const": false
        },
        "parse_key_primary_identity": {
          "const": false
        }
      }
    }
  }
}
