# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Generated full outputs — commit a SAMPLE + the generator instead (see README "generated-artifact rules")
out/
**/out/*
!**/out/.gitkeep

# Never commit: raw source images, OCR dumps, model weights, local QAC dumps, scratch
*.png
*.jpg
*.jpeg
*.tif
*.tiff
*.pdf
*.gz
*.zip
*.apkg
*.docx
*.doc
*.anki2
*.anki21
*.colpkg
*.mp3
*.ogg
*.wav
*.webm
*.mp4
*.svg
qac-*.tsv
*.weights
.scan*.json
*.local.json

# local scratch (agent slices, enriched inputs)
.p4*
.hover_*
.scan*

# full language state graph (commit the .sample + builder instead)
qamus/indexes/language_state_graph.json

# Tafsir MCP raw cache (internal evidence; commit examples/ only)
sources/tafsir_mcp/cache/*.json
dist/claude-ai/pack/
